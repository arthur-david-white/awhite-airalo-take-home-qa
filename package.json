{
  "name": "awhite-airalo-take-home-qa",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright + TypeScript test framework for the Airalo website (UI) and Airalo Partner API",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui",
    "test:api": "playwright test --project=api",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.6.0"
  }
}
